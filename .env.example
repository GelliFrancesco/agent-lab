# Environment variables for agent-lab
# COPY THIS FILE TO agent.env AND FILL IN YOUR VALUES
# agent.env is in .gitignore — NEVER commit real values

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Dashboard Auth ───────────────────────────────────────────────────────────
# Auto-generated on first run if not set here
DASHBOARD_TOKEN=
DASHBOARD_PIN=

# ── APIs ─────────────────────────────────────────────────────────────────────
# Optional: for live data fetching
ANTHROPIC_API_KEY=
FOTMOB_API_KEY=
